	component HW2 is
		port (
			clk_clk         : in  std_logic                    := 'X';             -- clk
			keys_export     : in  std_logic_vector(3 downto 0) := (others => 'X'); -- export
			leds_export     : out std_logic_vector(9 downto 0);                    -- export
			switches_export : in  std_logic_vector(9 downto 0) := (others => 'X')  -- export
		);
	end component HW2;

